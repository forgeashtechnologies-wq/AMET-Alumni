# ============================================
# AMET Alumni Portal — .gitignore
# ============================================

# Dependencies
node_modules/
.pnp/
.pnp.js
jspm_packages/

# Build output
/frontend/build/
/frontend/dist/
*.tsbuildinfo

# Environment variables (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
env.tmp
*.env
# But DO commit .env.example as templates
!.env.example

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/
.windsurf/
.emergent/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V*
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
/coverage/
.nyc_output/
cypress/screenshots/
cypress/videos/

# Misc
.cache/
tmp/
temp/

# Python (load testing etc)
.locust_env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
venv/
.venv/

# Archives
*.zip
*.tar.gz
*.tgz
archive/

# Supabase
supabase/.branches/
supabase/secrets/

# Docker
.docker/
docker-compose.override.yml

# Internal documentation
CONTRACT_PACK_INPUTS_DOSSIER.*
.todo.md
legal/
scripts/